<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_challenge_card"
    android:elevation="3dp"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- ── ROW 1: icon box + title/subtitle + streak badge ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <!-- Colored icon box -->
        <FrameLayout
            android:id="@+id/iconBox"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp">
            <TextView
                android:id="@+id/tvChallengeIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="▶"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Title + subtitle (expand) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvChallengeTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Challenge Title"
                android:textColor="#111111"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvChallengeStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="0 videos · 1/day"
                android:textColor="#999999"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Streak badge: fire + number + "day streak" -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginStart="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_fire"
                    android:tint="#FF6B35" />

                <TextView
                    android:id="@+id/tvStreakNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:text="0"
                    android:textColor="#FF6B35"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="day streak"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:layout_gravity="center" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── ROW 2: progress fraction + percent ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvProgressVideos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0/0 videos"
            android:textColor="#555555"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvProgressPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textColor="#555555"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── ROW 3: progress bar ── -->
    <ProgressBar
        android:id="@+id/progressChallenge"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginBottom="12dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/bg_progress_challenge"
        android:indeterminate="false" />

    <!-- ── ROW 4: status pill ── -->
    <TextView
        android:id="@+id/tvStatusPill"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_status_pending_pill"
        android:gravity="center"
        android:paddingTop="9dp"
        android:paddingBottom="9dp"
        android:text="🕐 Today: 0/1 videos – Start now!"
        android:textColor="#E65100"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>
