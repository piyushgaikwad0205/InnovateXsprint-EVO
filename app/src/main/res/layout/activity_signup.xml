<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/signup"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">



    <!-- Top Right Decorative Leaf -->
    <ImageView
        android:id="@+id/ivTopLeaf"
        android:layout_width="148dp"
        android:layout_height="145dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="-10dp"
        android:layout_marginEnd="-10dp"
        android:contentDescription="Decorative leaf"
        android:scaleType="fitEnd"
        android:src="@drawable/ic_leaf_single" />

    <!-- Scrollable Content -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Welcome Header -->
            <LinearLayout
                android:id="@+id/headerSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="50dp"
                android:paddingStart="40dp"
                android:paddingEnd="40dp">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/focus_flow"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign Up"
                    android:textColor="#000000"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create an account to track your focus"
                    android:textColor="#666666"
                    android:textSize="16sp"
                    android:layout_marginBottom="40dp" />

                <!-- Full Name Input -->
                <EditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edittext_underline"
                    android:hint="Full Name"
                    android:textColorHint="#999999"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:paddingBottom="12dp"
                    android:layout_marginBottom="24dp"
                    android:inputType="textPersonName" />

                <!-- Email Input -->
                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edittext_underline"
                    android:hint="Email Address"
                    android:textColorHint="#999999"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:paddingBottom="12dp"
                    android:layout_marginBottom="24dp"
                    android:inputType="textEmailAddress" />

                <!-- Password Input -->
                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edittext_underline"
                    android:hint="Password"
                    android:textColorHint="#999999"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:paddingBottom="12dp"
                    android:layout_marginBottom="24dp"
                    android:inputType="textPassword" />

                <!-- Sign Up Button -->
                <RelativeLayout
                    android:id="@+id/btnSignUp"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/btn_dark_bg"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="SIGN UP"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />
                </RelativeLayout>


                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Already have an account? "
                        android:textColor="#666666"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/tvSignIn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign In"
                        android:textColor="#000000"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <!-- Bottom Leaves -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="241dp"
                android:layout_alignParentBottom="true"
                android:scaleType="fitXY"
                android:src="@drawable/ic_login_leaves_1" />

            <ImageView
                android:id="@+id/imageView3"
                android:layout_width="160dp"
                android:layout_height="151dp"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="-2dp"
                app:srcCompat="@drawable/ic_leaf_tall" />


        </RelativeLayout>
</RelativeLayout>
