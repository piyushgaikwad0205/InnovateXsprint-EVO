<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:orientation="horizontal"
    android:paddingStart="10dp"
    android:paddingEnd="10dp">

    <!-- Y-Axis (Hours on Left) -->
    <LinearLayout
        android:layout_width="30dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="bottom"
        android:layout_marginBottom="22dp">
        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="8h" android:textSize="9sp" android:textColor="#A8A8A8" android:gravity="top|end" android:layout_marginEnd="6dp" />
        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="6h" android:textSize="9sp" android:textColor="#A8A8A8" android:gravity="top|end" android:layout_marginEnd="6dp" />
        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="4h" android:textSize="9sp" android:textColor="#A8A8A8" android:gravity="top|end" android:layout_marginEnd="6dp" />
        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="2h" android:textSize="9sp" android:textColor="#A8A8A8" android:gravity="top|end" android:layout_marginEnd="6dp" />
        <TextView android:layout_width="match_parent" android:layout_height="16dp" android:text="0h" android:textSize="9sp" android:textColor="#A8A8A8" android:gravity="bottom|end" android:layout_marginEnd="6dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="bottom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <!-- Sunday -->
            <RelativeLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="bottom|center_horizontal">
                    <View android:layout_width="6dp" android:layout_height="40dp" android:background="@drawable/bar_bg_grey" android:layout_marginEnd="2dp" />
                    <View android:layout_width="6dp" android:layout_height="60dp" android:background="@drawable/bar_bg_black" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Monday -->
            <RelativeLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="bottom|center_horizontal">
                    <View android:layout_width="6dp" android:layout_height="70dp" android:background="@drawable/bar_bg_grey" android:layout_marginEnd="2dp" />
                    <View android:layout_width="6dp" android:layout_height="100dp" android:background="@drawable/bar_bg_black" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Tuesday -->
            <RelativeLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="bottom|center_horizontal">
                    <View android:layout_width="6dp" android:layout_height="80dp" android:background="@drawable/bar_bg_grey" android:layout_marginEnd="2dp" />
                    <View android:layout_width="6dp" android:layout_height="70dp" android:background="@drawable/bar_bg_black" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Wednesday -->
            <RelativeLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="bottom|center_horizontal">
                    <View android:layout_width="6dp" android:layout_height="50dp" android:background="@drawable/bar_bg_grey" android:layout_marginEnd="2dp" />
                    <View android:layout_width="6dp" android:layout_height="130dp" android:background="@drawable/bar_bg_black" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Thursday -->
            <RelativeLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="bottom|center_horizontal">
                    <View android:layout_width="6dp" android:layout_height="70dp" android:background="@drawable/bar_bg_grey" android:layout_marginEnd="2dp" />
                    <View android:layout_width="6dp" android:layout_height="60dp" android:background="@drawable/bar_bg_black" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Friday -->
            <RelativeLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="bottom|center_horizontal">
                    <View android:layout_width="6dp" android:layout_height="80dp" android:background="@drawable/bar_bg_grey" android:layout_marginEnd="2dp" />
                    <View android:layout_width="6dp" android:layout_height="150dp" android:background="@drawable/bar_bg_black" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Saturday -->
            <RelativeLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="bottom|center_horizontal">
                    <View android:layout_width="6dp" android:layout_height="100dp" android:background="@drawable/bar_bg_grey" android:layout_marginEnd="2dp" />
                    <View android:layout_width="6dp" android:layout_height="80dp" android:background="@drawable/bar_bg_black" />
                </LinearLayout>
            </RelativeLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="S" android:gravity="center" android:textSize="10sp" android:textColor="#A8A8A8" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="M" android:gravity="center" android:textSize="10sp" android:textColor="#A8A8A8" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T" android:gravity="center" android:textSize="10sp" android:textColor="#A8A8A8" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="W" android:gravity="center" android:textSize="10sp" android:textColor="#A8A8A8" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T" android:gravity="center" android:textSize="10sp" android:textColor="#A8A8A8" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="F" android:gravity="center" android:textSize="10sp" android:textColor="#A8A8A8" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="S" android:gravity="center" android:textSize="10sp" android:textColor="#A8A8A8" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
