<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ===== HEADER ===== -->
    <RelativeLayout
        android:id="@+id/headerSpacer"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_alignParentTop="true"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#FFFFFF">

        <!-- Title + Subtitle -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Challenges"
                android:textColor="#111111"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Track your learning streaks"
                android:textColor="#999999"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Streak Pill (top right) -->
        <LinearLayout
            android:id="@+id/headerStreakPill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_streak_pill_header"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_fire"
                android:tint="#FF6B35" />

            <TextView
                android:id="@+id/tvHeaderStreakCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="0"
                android:textColor="#FF6B35"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <!-- ===== GREY CONTENT CONTAINER ===== -->
    <LinearLayout
        android:id="@+id/greyContentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerSpacer"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_main_content_container"
        android:orientation="vertical"
        android:paddingTop="10dp">

        <!-- Drag handle pill -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_drag_handle" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="90dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- ── ADD YOUTUBE PLAYLIST CARD ── -->
                <LinearLayout
                    android:id="@+id/addPlaylistCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_add_challenge_card"
                    android:elevation="4dp"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Card header row: YT icon + title -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="14dp">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_youtube"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add YouTube Playlist"
                            android:textColor="#111111"
                            android:textSize="17sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- URL input row -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_url_input_field">

                        <ImageView
                            android:id="@+id/ivLinkIcon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="14dp"
                            android:src="@drawable/ic_link_icon" />

                        <EditText
                            android:id="@+id/etPlaylistUrl"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toEndOf="@id/ivLinkIcon"
                            android:layout_marginStart="8dp"
                            android:background="@null"
                            android:hint="Paste playlist URL here..."
                            android:textColorHint="#AAAAAA"
                            android:textColor="#111111"
                            android:textSize="14sp"
                            android:inputType="textUri"
                            android:paddingEnd="14dp"
                            android:singleLine="true"
                            android:imeOptions="actionDone" />
                    </RelativeLayout>

                    <!-- + Add Challenge button -->
                    <TextView
                        android:id="@+id/btnAddChallenge"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_add_btn_black"
                        android:gravity="center"
                        android:text="+ Add Challenge"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- ── ACTIVE CHALLENGES SECTION HEADER ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Active Challenges"
                        android:textColor="#111111"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSeeAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See all"
                        android:textColor="#FF6B35"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- ── EMPTY STATE ── -->
                <LinearLayout
                    android:id="@+id/llEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="32dp"
                    android:paddingBottom="32dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_challenges"
                        android:tint="#CCCCCC"
                        android:layout_gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="No challenges yet"
                        android:textColor="#888888"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="Paste a YouTube playlist URL above&#10;and tap + Add Challenge to get started"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:layout_gravity="center" />
                </LinearLayout>

                <!-- ── CHALLENGE CARDS CONTAINER ── -->
                <LinearLayout
                    android:id="@+id/llChallengesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- ===== BOTTOM NAVIGATION BAR ===== -->
    <RelativeLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/bottomNavMenu"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:weightSum="5">

            <!-- Home -->
            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivHome"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_home"
                    android:tint="#888888" />
                <TextView
                    android:id="@+id/tvHomeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Home"
                    android:textColor="#888888"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Tour -->
            <LinearLayout
                android:id="@+id/navPlanner"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivPlanner"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_location"
                    android:tint="#888888" />
                <TextView
                    android:id="@+id/tvPlannerLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Planner"
                    android:textColor="#888888"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Tracker -->
            <LinearLayout
                android:id="@+id/navTracker"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivTracker"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_graph_new"
                    android:tint="#888888" />
                <TextView
                    android:id="@+id/tvTrackerLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tracker"
                    android:textColor="#888888"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Challenges (ACTIVE - orange) -->
            <LinearLayout
                android:id="@+id/navMusic"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivMusic"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_challenges"
                    android:tint="#FF6B35" />
                <TextView
                    android:id="@+id/tvMusicLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Challenges"
                    android:textColor="#FF6B35"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Profile -->
            <LinearLayout
                android:id="@+id/navAbout"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivAbout"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_profile"
                    android:tint="#888888" />
                <TextView
                    android:id="@+id/tvAboutLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Profile"
                    android:textColor="#888888"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

</RelativeLayout>
