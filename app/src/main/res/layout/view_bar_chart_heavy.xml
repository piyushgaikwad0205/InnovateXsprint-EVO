<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="240dp"
    android:orientation="horizontal"
    android:paddingStart="10dp"
    android:paddingEnd="10dp">

    <!-- Y-Axis (Hours on Left) -->
    <LinearLayout
        android:layout_width="30dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="bottom"
        android:layout_marginBottom="26dp">
        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="10h" android:textSize="10sp" android:textColor="#A8A8A8" android:gravity="top|end" android:layout_marginEnd="6dp" />
        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="8h" android:textSize="10sp" android:textColor="#A8A8A8" android:gravity="top|end" android:layout_marginEnd="6dp" />
        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="6h" android:textSize="10sp" android:textColor="#A8A8A8" android:gravity="top|end" android:layout_marginEnd="6dp" />
        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="4h" android:textSize="10sp" android:textColor="#A8A8A8" android:gravity="top|end" android:layout_marginEnd="6dp" />
        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:text="2h" android:textSize="10sp" android:textColor="#A8A8A8" android:gravity="top|end" android:layout_marginEnd="6dp" />
        <TextView android:layout_width="match_parent" android:layout_height="20dp" android:text="0h" android:textSize="10sp" android:textColor="#A8A8A8" android:gravity="bottom|end" android:layout_marginEnd="6dp" />
    </LinearLayout>

    <!-- Chart Body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="bottom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <!-- Sunday -->
            <RelativeLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="bottom|center_horizontal">
                    <View android:layout_width="8dp" android:layout_height="60dp" android:background="@drawable/bar_bg_grey" android:layout_marginEnd="2dp" />
                    <View android:layout_width="8dp" android:layout_height="90dp" android:background="@drawable/bar_bg_black" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Monday -->
            <RelativeLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="bottom|center_horizontal">
                    <View android:layout_width="8dp" android:layout_height="120dp" android:background="@drawable/bar_bg_grey" android:layout_marginEnd="2dp" />
                    <View android:layout_width="8dp" android:layout_height="160dp" android:background="@drawable/bar_bg_black" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Tuesday -->
            <RelativeLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="bottom|center_horizontal">
                    <View android:layout_width="8dp" android:layout_height="140dp" android:background="@drawable/bar_bg_grey" android:layout_marginEnd="2dp" />
                    <View android:layout_width="8dp" android:layout_height="110dp" android:background="@drawable/bar_bg_black" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Wednesday -->
            <RelativeLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="bottom|center_horizontal">
                    <View android:layout_width="8dp" android:layout_height="80dp" android:background="@drawable/bar_bg_grey" android:layout_marginEnd="2dp" />
                    <View android:layout_width="8dp" android:layout_height="180dp" android:background="@drawable/bar_bg_black" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Thursday -->
            <RelativeLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="bottom|center_horizontal">
                    <View android:layout_width="8dp" android:layout_height="100dp" android:background="@drawable/bar_bg_grey" android:layout_marginEnd="2dp" />
                    <View android:layout_width="8dp" android:layout_height="80dp" android:background="@drawable/bar_bg_black" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Friday -->
            <RelativeLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="bottom|center_horizontal">
                    <View android:layout_width="8dp" android:layout_height="120dp" android:background="@drawable/bar_bg_grey" android:layout_marginEnd="2dp" />
                    <View android:layout_width="8dp" android:layout_height="200dp" android:background="@drawable/bar_bg_black" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Saturday -->
            <RelativeLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="bottom|center_horizontal">
                    <View android:layout_width="8dp" android:layout_height="160dp" android:background="@drawable/bar_bg_grey" android:layout_marginEnd="2dp" />
                    <View android:layout_width="8dp" android:layout_height="130dp" android:background="@drawable/bar_bg_black" />
                </LinearLayout>
            </RelativeLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sun" android:gravity="center" android:textSize="10sp" android:textColor="#A8A8A8" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Mon" android:gravity="center" android:textSize="10sp" android:textColor="#A8A8A8" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tue" android:gravity="center" android:textSize="10sp" android:textColor="#A8A8A8" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Wed" android:gravity="center" android:textSize="10sp" android:textColor="#A8A8A8" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Thu" android:gravity="center" android:textSize="10sp" android:textColor="#A8A8A8" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Fri" android:gravity="center" android:textSize="10sp" android:textColor="#A8A8A8" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sat" android:gravity="center" android:textSize="10sp" android:textColor="#A8A8A8" android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
