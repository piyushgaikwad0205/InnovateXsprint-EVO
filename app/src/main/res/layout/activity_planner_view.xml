<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/planer_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ===== MAIN CONTENT ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavContainer"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER ===== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/tvPlanerTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Planner"
                    android:textColor="#000000"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed" />

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/focus_flow"
                    android:scaleType="fitCenter" />
            </RelativeLayout>

            <!-- Task / Date Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/task_badge_bg"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="Task"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTodayDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="Date"
                    android:textColor="#121417"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- ===== GREETING + ADD TOUR ===== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="42dp">

                <LinearLayout
                    android:id="@+id/greetingBlock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreetingText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good Morning"
                        android:textColor="#3A4646"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvGreetingName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User!!"
                        android:textColor="#000000"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- + Add tour button -->
                <LinearLayout
                    android:id="@+id/btnAddTour"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_oval_stroke"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="22dp"
                    android:paddingEnd="26dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_plus_thin"
                        android:tint="#3A4646" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Add tour"
                        android:textColor="#3A4646"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </RelativeLayout>

            <!-- ===== YEAR SELECTOR ===== -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="12dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- 2025 (selected) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_oval_stroke"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:text="2025"
                        android:textColor="#3A4646"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:text="2026"
                        android:textColor="#3A4646"
                        android:textSize="15sp"
                        android:alpha="0.4" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:text="2027"
                        android:textColor="#3A4646"
                        android:textSize="15sp"
                        android:alpha="0.4" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:text="2028"
                        android:textColor="#3A4646"
                        android:textSize="15sp"
                        android:alpha="0.4" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:text="2029"
                        android:textColor="#3A4646"
                        android:textSize="15sp"
                        android:alpha="0.4" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:text="2030"
                        android:textColor="#3A4646"
                        android:textSize="15sp"
                        android:alpha="0.4" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- ===== MONTH SELECTOR ===== -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- MAR (selected) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_oval_stroke"
                        android:paddingHorizontal="18dp"
                        android:paddingVertical="8dp"
                        android:text="MAR"
                        android:textColor="#3A4646"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:text="APR"
                        android:textColor="#3A4646"
                        android:textSize="15sp"
                        android:alpha="0.4" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:text="MAY"
                        android:textColor="#3A4646"
                        android:textSize="15sp"
                        android:alpha="0.4" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:text="JUN"
                        android:textColor="#3A4646"
                        android:textSize="15sp"
                        android:alpha="0.4" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:text="JUL"
                        android:textColor="#3A4646"
                        android:textSize="15sp"
                        android:alpha="0.4" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:text="AUG"
                        android:textColor="#3A4646"
                        android:textSize="15sp"
                        android:alpha="0.4" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:text="SEP"
                        android:textColor="#3A4646"
                        android:textSize="15sp"
                        android:alpha="0.4" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- ===== CALENDAR CARD ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_calendar_rounded"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="24dp">

                <!-- Calendar Header Row: MARCH, 2025 | 1 EVENT -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="MARCH, 2025"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/active_tab_bg"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="1 EVENT"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- Day Headers: S M T W T F S -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView style="@style/CalDayHeader" android:text="S" />
                    <TextView style="@style/CalDayHeader" android:text="M" />
                    <TextView style="@style/CalDayHeader" android:text="T" />
                    <TextView style="@style/CalDayHeader" android:text="W" />
                    <TextView style="@style/CalDayHeader" android:text="T" />
                    <TextView style="@style/CalDayHeader" android:text="F" />
                    <TextView style="@style/CalDayHeader" android:text="S" />
                </LinearLayout>

                <!-- Week 1: 1 2 3 4 5 6 7 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView style="@style/CalDay" android:text="1" />
                    <TextView style="@style/CalDay" android:text="2" />
                    <TextView style="@style/CalDay" android:text="3" />
                    <TextView style="@style/CalDay" android:text="4" />
                    <!-- Day 5: highlighted with circle -->
                    <TextView style="@style/CalDayHighlight" android:text="5" />
                    <TextView style="@style/CalDay" android:text="6" />
                    <!-- Day 7: highlighted with circle -->
                    <TextView style="@style/CalDayHighlight" android:text="7" />
                </LinearLayout>

                <!-- Week 2: 8 9 10 11 12 13 14 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView style="@style/CalDay" android:text="8" />
                    <TextView style="@style/CalDay" android:text="9" />
                    <TextView style="@style/CalDay" android:text="10" />
                    <TextView style="@style/CalDay" android:text="11" />
                    <TextView style="@style/CalDay" android:text="12" />
                    <TextView style="@style/CalDay" android:text="13" />
                    <TextView style="@style/CalDay" android:text="14" />
                </LinearLayout>

                <!-- Week 3: 15 16 17 18 19 20 21 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView style="@style/CalDay" android:text="15" />
                    <TextView style="@style/CalDay" android:text="16" />
                    <TextView style="@style/CalDay" android:text="17" />
                    <TextView style="@style/CalDay" android:text="18" />
                    <TextView style="@style/CalDay" android:text="19" />
                    <TextView style="@style/CalDay" android:text="20" />
                    <TextView style="@style/CalDay" android:text="21" />
                </LinearLayout>

                <!-- Week 4: 22 23 24 25 26 27 28 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView style="@style/CalDay" android:text="22" />
                    <TextView style="@style/CalDay" android:text="23" />
                    <TextView style="@style/CalDay" android:text="24" />
                    <TextView style="@style/CalDay" android:text="25" />
                    <TextView style="@style/CalDay" android:text="26" />
                    <TextView style="@style/CalDay" android:text="27" />
                    <TextView style="@style/CalDay" android:text="28" />
                </LinearLayout>

                <!-- Week 5: 29 30 31 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView style="@style/CalDay" android:text="29" />
                    <TextView style="@style/CalDay" android:text="30" />
                    <TextView style="@style/CalDay" android:text="31" />
                    <TextView style="@style/CalDay" android:text="" />
                    <TextView style="@style/CalDay" android:text="" />
                    <TextView style="@style/CalDay" android:text="" />
                    <TextView style="@style/CalDay" android:text="" />
                </LinearLayout>

            </LinearLayout>

            <!-- ===== TRIP / SCENES CARD ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="40dp"
                android:background="@drawable/bg_scenes_card"
                android:orientation="horizontal"
                android:padding="0dp"
                android:clipToOutline="true">

                <!-- Left Image Section -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="130dp"
                    android:layout_height="130dp"
                    android:src="@drawable/scenes"
                    android:scaleType="centerCrop"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    app:shapeAppearanceOverlay="@style/RoundedSideImage" />

                <!-- Right Info Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Timer Pill -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_oval_stroke"
                        android:backgroundTint="#88FFFFFF"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="3 D : 10 H : 05 M"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <!-- Date and Duration -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="JAN 5 - JAN 7  •  2N3D"
                        android:textColor="#DDFFFFFF"
                        android:textSize="12sp"
                        android:letterSpacing="0.05" />

                    <!-- Trip Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Go To VNIT College for....."
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Location Row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_location"
                            android:tint="#DDFFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="Nagpur, Maharastra, India"
                            android:textColor="#DDFFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ===== RECENT TASKS SECTION ===== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Your Tasks"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTaskCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="-- pending • -- done"
                    android:textColor="#888888"
                    android:textSize="12sp" />
            </RelativeLayout>

            <!-- Dynamic Firebase Tasks Container -->
            <LinearLayout
                android:id="@+id/recentTasksContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="100dp" />

        </LinearLayout>
    </ScrollView>

    <!-- ===== BOTTOM NAVIGATION BAR (Simplified) ===== -->
    <RelativeLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/bottomNavMenu"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:weightSum="5">

            <!-- Home -->
            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivHome"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_home"
                    android:tint="#888888" />
                <TextView
                    android:id="@+id/tvHomeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Home"
                    android:textColor="#888888"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Tour (Active) -->
            <LinearLayout
                android:id="@+id/navPlanner"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivPlanner"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_location"
                    android:tint="#111111" />
                <TextView
                    android:id="@+id/tvPlannerLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tour"
                    android:textColor="#111111"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Streak -->
            <LinearLayout
                android:id="@+id/navStreak"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivStreak"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_fire"
                    android:tint="#FF6B35" />
                <TextView
                    android:id="@+id/tvStreakCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="0"
                    android:textColor="#FF6B35"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Music -->
            <LinearLayout
                android:id="@+id/navMusic"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivMusic"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_music"
                    android:tint="#888888" />
                <TextView
                    android:id="@+id/tvMusicLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Music"
                    android:textColor="#888888"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Profile -->
            <LinearLayout
                android:id="@+id/navAbout"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivAbout"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_profile"
                    android:tint="#888888" />
                <TextView
                    android:id="@+id/tvAboutLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Profile"
                    android:textColor="#888888"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

</RelativeLayout>
